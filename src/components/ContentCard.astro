---
interface Props {
  href: string;
  label: string;
  title: string;
  description: string;
  date?: string;
}

const { href, label, title, description, date } = Astro.props;
---

<article class="group flex h-full flex-col rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-indigo-200 hover:shadow-lg">
  <div class="flex items-center justify-between gap-3">
    <span class="text-[10px] font-black uppercase tracking-[0.2em] text-indigo-600">{label}</span>
    {date && <time class="text-xs font-semibold text-slate-400">{date}</time>}
  </div>
  <h3 class="mt-4 text-xl font-black leading-tight tracking-tight text-slate-950"><a class="after:absolute after:inset-0" href={href}>{title}</a></h3>
  <p class="mt-3 flex-1 text-sm font-medium leading-relaxed text-slate-600">{description}</p>
  <span class="mt-5 text-xs font-black text-indigo-600 group-hover:text-indigo-700">Read more <span aria-hidden="true">→</span></span>
</article>

<style>
  article { position: relative; }
</style>
