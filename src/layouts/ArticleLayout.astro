---
import SiteLayout from './SiteLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import { formatDate } from '../lib/content';
import { SITE } from '../site';

interface Source {
  title: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  sectionLabel: string;
  sectionPath: string;
  published: Date;
  updated?: Date;
  readingMinutes?: number;
  tags?: string[];
  sources?: Source[];
  affiliate?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  sectionLabel,
  sectionPath,
  published,
  updated,
  readingMinutes,
  tags = [],
  sources = [],
  affiliate = false,
} = Astro.props;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: published.toISOString(),
  dateModified: (updated ?? published).toISOString(),
  author: { '@type': 'Organization', name: SITE.editorialName },
  publisher: { '@type': 'Organization', name: SITE.name },
  mainEntityOfPage: new URL(canonicalPath, Astro.site).toString(),
};
---

<SiteLayout title={title} description={description} canonicalPath={canonicalPath} type="article" publishedTime={published} updatedTime={updated} schema={articleSchema}>
  <article class="mx-auto max-w-4xl px-4 py-12 sm:px-6 sm:py-16">
    <nav class="text-xs font-bold text-slate-500" aria-label="Breadcrumb">
      <a class="hover:text-indigo-600" href="/">Home</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <a class="hover:text-indigo-600" href={`/${sectionPath}/`}>{sectionLabel}</a>
    </nav>
    <header class="mt-8 border-b border-slate-200 pb-9">
      <p class="text-xs font-black uppercase tracking-[0.22em] text-indigo-600">{sectionLabel}</p>
      <h1 class="mt-4 text-4xl font-black leading-[1.08] tracking-tight text-slate-950 sm:text-5xl">{title}</h1>
      <p class="mt-5 max-w-3xl text-lg font-medium leading-relaxed text-slate-600">{description}</p>
      <div class="mt-6 flex flex-wrap gap-x-4 gap-y-2 text-xs font-bold text-slate-500">
        <span>By {SITE.editorialName}</span>
        <time datetime={published.toISOString()}>Published {formatDate(published)}</time>
        {updated && <time datetime={updated.toISOString()}>Updated {formatDate(updated)}</time>}
        {readingMinutes && <span>{readingMinutes} min read</span>}
      </div>
    </header>

    {affiliate && <p class="mt-8 rounded-xl border border-indigo-100 bg-indigo-50 px-4 py-3 text-xs font-semibold leading-relaxed text-indigo-950">This page may contain affiliate links. Recommendations are selected for relevance, not payout. <a class="font-black underline" href="/affiliate-disclosure/">Read our disclosure.</a></p>}

    <div class="article-body mt-10">
      <slot />
    </div>

    <AdSlot placement="article-end" />

    {sources.length > 0 && (
      <section class="mt-12 border-t border-slate-200 pt-8" aria-labelledby="sources-heading">
        <h2 id="sources-heading" class="text-xl font-black text-slate-950">Sources and further reading</h2>
        <ul class="mt-4 space-y-3">
          {sources.map((source) => <li><a class="text-sm font-bold text-indigo-700 underline decoration-indigo-200 underline-offset-4 hover:decoration-indigo-600" href={source.url} rel="noreferrer">{source.title}</a></li>)}
        </ul>
      </section>
    )}

    {tags.length > 0 && <p class="mt-10 text-xs font-semibold text-slate-500">Topics: {tags.join(' · ')}</p>}

    <aside class="mt-12 rounded-3xl bg-slate-950 p-7 text-white sm:p-9">
      <p class="text-xs font-black uppercase tracking-widest text-indigo-300">Put it to work</p>
      <h2 class="mt-3 text-2xl font-black">Estimate your own production run</h2>
      <p class="mt-3 max-w-2xl text-sm font-medium leading-relaxed text-slate-300">Use your stitch count, garment, machine configuration, and shop calibration. No account required.</p>
      <a class="mt-6 inline-flex min-h-11 items-center rounded-xl bg-indigo-500 px-5 text-sm font-black text-white hover:bg-indigo-400" href="/calculator/">Open the free calculator <span class="ml-2" aria-hidden="true">→</span></a>
    </aside>
  </article>
</SiteLayout>

<style is:global>
  .article-body { color: rgb(51 65 85); font-size: 1.0625rem; line-height: 1.8; }
  .article-body h2 { margin-top: 2.5rem; color: rgb(15 23 42); font-size: 1.7rem; font-weight: 900; letter-spacing: -0.025em; line-height: 1.2; }
  .article-body h3 { margin-top: 2rem; color: rgb(15 23 42); font-size: 1.25rem; font-weight: 900; }
  .article-body p, .article-body ul, .article-body ol { margin-top: 1.2rem; }
  .article-body ul, .article-body ol { padding-left: 1.4rem; }
  .article-body ul { list-style: disc; }
  .article-body ol { list-style: decimal; }
  .article-body li + li { margin-top: .5rem; }
  .article-body a { color: rgb(67 56 202); font-weight: 700; text-decoration: underline; text-underline-offset: 3px; }
  .article-body strong { color: rgb(15 23 42); font-weight: 800; }
  .article-body blockquote { margin-top: 1.5rem; border-left: 4px solid rgb(99 102 241); background: rgb(238 242 255); padding: 1rem 1.25rem; color: rgb(49 46 129); }
  .article-body table { margin-top: 1.5rem; width: 100%; border-collapse: collapse; font-size: .9rem; }
  .article-body th, .article-body td { border: 1px solid rgb(226 232 240); padding: .75rem; text-align: left; }
  .article-body th { background: rgb(248 250 252); color: rgb(15 23 42); }
</style>
