---
import SiteLayout from '../layouts/SiteLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import { entryUrl, formatDate, getAllContent, sectionLabel } from '../lib/content';

const latest = (await getAllContent()).slice(0, 6);
const applicationSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'EmbroideryCalc',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any modern web browser',
  isAccessibleForFree: true,
  offers: { '@type': 'Offer', price: 0, priceCurrency: 'USD' },
  featureList: ['Embroidery production time estimates', 'Tajima DST analysis', 'Artwork color extraction', 'Madeira thread color suggestions'],
};
---

<SiteLayout schema={applicationSchema}>
  <section class="overflow-hidden bg-slate-950 text-white">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 py-16 sm:px-6 sm:py-24 lg:grid-cols-[1.15fr_.85fr] lg:items-center">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.25em] text-indigo-300">Built for embroidery production</p>
        <h1 class="mt-5 max-w-4xl text-5xl font-black leading-[1.02] tracking-tight sm:text-6xl">A clearer answer to “how long will this job take?”</h1>
        <p class="mt-6 max-w-2xl text-lg font-medium leading-relaxed text-slate-300">Estimate real production time, inspect DST files, and turn image colors into nearby Madeira thread options—all in your browser, without an account.</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a class="inline-flex min-h-12 items-center justify-center rounded-xl bg-indigo-500 px-6 text-sm font-black text-white hover:bg-indigo-400" href="/calculator/">Calculate production time</a>
          <a class="inline-flex min-h-12 items-center justify-center rounded-xl border border-slate-700 px-6 text-sm font-black text-white hover:bg-slate-900" href="/methodology/">See how estimates work</a>
        </div>
        <div class="mt-8 flex flex-wrap gap-x-5 gap-y-2 text-xs font-bold text-slate-400">
          <span>Free to use</span><span aria-hidden="true">•</span><span>No account</span><span aria-hidden="true">•</span><span>Files stay local</span>
        </div>
      </div>
      <div class="rounded-[2rem] border border-slate-700 bg-slate-900 p-6 shadow-2xl sm:p-8">
        <p class="text-xs font-black uppercase tracking-widest text-indigo-300">One practical workspace</p>
        <div class="mt-6 space-y-4">
          <a href="/calculator/" class="block rounded-2xl bg-white p-5 text-slate-950 transition hover:-translate-y-0.5"><span class="text-sm font-black">Production time calculator</span><span class="mt-1 block text-xs font-medium text-slate-500">Machine, operator, setup, stops, and buffer</span></a>
          <a href="/tools/dst-stitch-count/" class="block rounded-2xl border border-slate-700 p-5 transition hover:border-indigo-400"><span class="text-sm font-black">DST file analyzer</span><span class="mt-1 block text-xs font-medium text-slate-400">Stitches, colors, dimensions, jumps, trims, and warnings</span></a>
          <a href="/tools/thread-color-match/" class="block rounded-2xl border border-slate-700 p-5 transition hover:border-indigo-400"><span class="text-sm font-black">Photo-to-thread matcher</span><span class="mt-1 block text-xs font-medium text-slate-400">Pick a region or palette, then compare nearby Madeira options</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20">
    <div class="max-w-3xl">
      <p class="text-xs font-black uppercase tracking-[0.22em] text-indigo-600">Built for useful answers</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">From design file to production plan</h2>
      <p class="mt-4 text-base font-medium leading-relaxed text-slate-600">The calculator separates machine occupancy from operator work, supports shop-specific calibration, and explains the factors behind every estimate.</p>
    </div>
    <div class="mt-9 grid gap-5 md:grid-cols-3">
      <div class="rounded-3xl border border-slate-200 bg-white p-6"><p class="text-lg font-black">1. Read the design</p><p class="mt-2 text-sm font-medium leading-relaxed text-slate-600">Upload a DST or enter stitches and colors manually. File parsing happens locally.</p></div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6"><p class="text-lg font-black">2. Describe the run</p><p class="mt-2 text-sm font-medium leading-relaxed text-slate-600">Add garments, locations, heads, RPM, handling, stops, and expected downtime.</p></div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6"><p class="text-lg font-black">3. Compare reality</p><p class="mt-2 text-sm font-medium leading-relaxed text-slate-600">Record the actual finish and refine the local calibration profile as your shop learns.</p></div>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div><p class="text-xs font-black uppercase tracking-[0.22em] text-indigo-600">Embroidery field notes</p><h2 class="mt-3 text-3xl font-black tracking-tight">Guides, explainers, and analysis</h2></div>
        <a class="text-sm font-black text-indigo-700" href="/guides/">Browse all guides →</a>
      </div>
      <div class="mt-9 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {latest.map(({ section, entry }) => <ContentCard href={entryUrl(section, entry)} label={sectionLabel[section]} title={entry.data.title} description={entry.data.description} date={formatDate(entry.data.published)} />)}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-16 text-center sm:px-6 sm:py-20">
    <p class="text-xs font-black uppercase tracking-[0.22em] text-indigo-600">Transparent by design</p>
    <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950">Useful estimates, honest limits</h2>
    <p class="mx-auto mt-4 max-w-3xl text-base font-medium leading-relaxed text-slate-600">Production varies with digitizing quality, operators, machines, materials, and interruptions. We publish the model, keep assumptions editable, and label approximations—including color matches and inferred DST trims.</p>
    <div class="mt-7 flex flex-wrap justify-center gap-3"><a class="rounded-xl border border-slate-200 bg-white px-5 py-3 text-sm font-black" href="/methodology/">Read the methodology</a><a class="rounded-xl border border-slate-200 bg-white px-5 py-3 text-sm font-black" href="/privacy/">See the privacy approach</a></div>
  </section>
</SiteLayout>
