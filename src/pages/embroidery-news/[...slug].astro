---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  return (await getCollection('news')).map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

interface Props { entry: CollectionEntry<'news'> }
const { entry } = Astro.props;
const { Content } = await render(entry);
---
<ArticleLayout title={entry.data.title} description={entry.data.description} canonicalPath={`/embroidery-news/${entry.id}/`} sectionLabel="News & analysis" sectionPath="embroidery-news" published={entry.data.published} updated={entry.data.updated} readingMinutes={entry.data.readingMinutes} tags={entry.data.tags} sources={entry.data.sources} affiliate={entry.data.affiliate}>
  <Content />
</ArticleLayout>
