---
import SiteLayout from '../../layouts/SiteLayout.astro';
const description = 'Read Tajima DST stitch count, color changes, dimensions, jumps, inferred trims, thread travel, thread estimates, and file warnings locally.';
const schema = {
  '@context': 'https://schema.org', '@type': 'SoftwareApplication', name: 'Free DST Stitch Count Reader', applicationCategory: 'DesignApplication', operatingSystem: 'Web browser', isAccessibleForFree: true, description,
};
---
<SiteLayout title="Free DST Stitch Count Reader" description={description} canonicalPath="/tools/dst-stitch-count/" schema={schema}>
  <section class="mx-auto max-w-5xl px-4 py-14 sm:px-6 sm:py-20">
    <p class="text-xs font-black uppercase tracking-[0.22em] text-indigo-600">Browser-based Tajima file reader</p>
    <h1 class="mt-4 text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">Check a DST stitch count without uploading the file to a server</h1>
    <p class="mt-5 max-w-3xl text-lg font-medium leading-relaxed text-slate-600">EmbroideryCalc reads the stitch-command stream in your browser, then can move the result directly into a production estimate.</p>
    <a class="mt-8 inline-flex min-h-12 items-center rounded-xl bg-indigo-600 px-6 text-sm font-black text-white hover:bg-indigo-700" href="/calculator/">Open DST analyzer and calculator →</a>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {['Stitch count and color changes', 'Design width and height', 'Jump count and inferred trims', 'Stitch and travel distance', 'Estimated top and bobbin thread', 'End-command and file-health warnings'].map((item) => <div class="rounded-2xl border border-slate-200 bg-white p-5 text-sm font-black text-slate-800">{item}</div>)}
    </div>

    <div class="mt-14 grid gap-10 lg:grid-cols-2">
      <div><h2 class="text-2xl font-black">What a DST can tell you</h2><p class="mt-4 text-sm font-medium leading-relaxed text-slate-600">DST records movement commands and color-change stops; it does not contain rich thread-color names or a universal, explicit trim count. The analyzer reports color segments and flags trims inferred from jump patterns, so you can review them before quoting.</p></div>
      <div><h2 class="text-2xl font-black">What stays private</h2><p class="mt-4 text-sm font-medium leading-relaxed text-slate-600">The file is read with browser code on your device. The design file, its filename, and its extracted measurements are not sent to EmbroideryCalc analytics. Clearing the page removes the pending file analysis.</p></div>
    </div>
    <div class="mt-12 rounded-3xl border border-amber-200 bg-amber-50 p-6"><h2 class="text-lg font-black text-amber-950">Verify before production</h2><p class="mt-2 text-sm font-medium leading-relaxed text-amber-900">DST conventions vary by exporter and digitizer. Preview the design in trusted embroidery software and run a sew-out when machine safety, exact trim behavior, registration, or material performance matters.</p></div>
  </section>
</SiteLayout>
