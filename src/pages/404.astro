---
import SiteLayout from '../layouts/SiteLayout.astro';
---
<SiteLayout title="Page Not Found" description="The requested EmbroideryCalc page could not be found." canonicalPath="/404/" noindex>
  <section class="mx-auto max-w-3xl px-4 py-24 text-center sm:px-6">
    <p class="text-xs font-black uppercase tracking-[0.22em] text-indigo-600">404 · Page not found</p>
    <h1 class="mt-4 text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">That thread went somewhere else.</h1>
    <p class="mx-auto mt-5 max-w-xl text-base font-medium leading-relaxed text-slate-600">The link may be old or the page may have moved. The calculator and current learning library are still available.</p>
    <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row"><a class="rounded-xl bg-indigo-600 px-6 py-3 text-sm font-black text-white" href="/calculator/">Open calculator</a><a class="rounded-xl border border-slate-200 bg-white px-6 py-3 text-sm font-black text-slate-800" href="/">Return home</a></div>
  </section>
</SiteLayout>
