# Absolute production origin used for canonical URLs, sitemap, RSS, and robots.
SITE_URL=https://embroiderycalc-pro.pages.dev

# Configure either GTM or direct GA4. Both remain off until the visitor consents.
PUBLIC_GTM_ID=
PUBLIC_GA_MEASUREMENT_ID=

# Paste verification tokens from Google Search Console and Bing Webmaster Tools.
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=

# Development-only visual check for reserved sponsor placements.
PUBLIC_SHOW_AD_PLACEHOLDERS=false

# Optional Pro Pages Functions. Configure these in Cloudflare; encrypt every
# secret. See docs/CLOUDFLARE_PRO_SETUP.md. Do not expose them as PUBLIC_ vars.
AUTH_FROM_EMAIL=
RESEND_API_KEY=
PRINTAVO_ENCRYPTION_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
